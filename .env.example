# Stripe secret key (find at https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Your shop's public URL (used for SEO, OG tags, and Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Set to "prod" to use production Stripe Price IDs, otherwise uses test IDs
PRICE_MODE=test
