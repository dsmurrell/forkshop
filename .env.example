# Stripe secret key (find at https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe webhook signing secret (find at https://dashboard.stripe.com/webhooks)
# Required for inventory management (stock hold/release on checkout expiry)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Your shop's public URL (used for SEO, OG tags, and Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
